Package: dory
Architecture: any
Pre-Depends: ${misc:Pre-Depends}
Depends:
 cinnamon-desktop-data (>= 4.8.0),
 cinnamon-l10n,
 desktop-file-utils (>= 0.7),
 gsettings-desktop-schemas,
 gvfs (>= 1.3.2),
 libglib2.0-data,
 libdory-extension1 (= ${binary:Version}),
 dory-data (= ${source:Version}),
 shared-mime-info (>= 0.50),
 poppler-utils,
 exif,
 id3,
 catdoc,
 untex,
 html2text,
 python3-xlrd,
 xapp-symbolic-icons (>= 1.0.7),
 ${misc:Depends},
 ${shlibs:Depends},
Recommends:
 gvfs-backends,
 gvfs-fuse,
 librsvg2-common,
 dory-fileroller,
 gnome-disk-utility
Suggests: eog, evince | pdf-viewer, totem | mp3-decoder, xdg-user-dirs
Description: file manager and graphical shell for Cinnamon
 Dory is the official file manager for the Cinnamon desktop. It allows
 to browse directories, preview files and launch applications associated
 with them. It is also responsible for handling the icons on the Cinnamon
 desktop. It works on local and remote filesystems.
 .
 Several icon themes and components for viewing different kinds of files
 are available in separate packages.

